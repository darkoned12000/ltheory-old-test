# Part of the ltheory-old-test modernization effort (Revamp Work).
# See NOTICE and LICENSE.GPL. Original engine (c) Josh Parnell, public domain.
#
# Scoped to SAFE, mechanical modernization only. Deliberately conservative
# (see AGENTS.md §8c.3 non-goals):
#   - Keep -fno-exceptions: no exception-based checks.
#   - Keep Reference<T> + the reflection macros: do NOT enable checks that would
#     rewrite ownership (no modernize-make-*, no cppcoreguidelines-owning-memory).
#   - The engine has ~1094 C-style casts and deliberate *(T const*)0 idioms; we
#     surface them as warnings but fix them by hand, per-subsystem, not en masse.
#
# Run per-subsystem, e.g.:
#   run-clang-tidy -p build src/liblt/LTE            # report only
#   run-clang-tidy -p build -fix src/liblt/LTE/Xxx   # apply fixes to one dir
# Requires build/compile_commands.json (configure.py exports it).
#
# SAFE set only (applied with -fix):
#   modernize-use-override          - annotate virtual overrides (mechanical, safe)
#   modernize-use-bool-literals     - true/false instead of 1/0 for bools
#   modernize-redundant-void-arg    - drop redundant (void) param lists
#   modernize-use-equals-default    - = default trivial special members
#   modernize-use-equals-delete     - = delete where appropriate
#   readability-redundant-member-init / -control-flow  - small cleanups
#
# DELIBERATELY EXCLUDED from -fix (review by hand / skip):
#   modernize-use-nullptr      - `0` is overloaded as integer-zero in this code;
#                                auto-fixing would turn int 0 into nullptr wrongly.
#   modernize-use-using        - 1335 typedefs across headers; mechanical churn,
#                                defer (low value, large diff).
#   google-readability-casting - 2155 C-style casts; many are the intentional
#                                *(T const*)0 introspection idioms (see §8c.1).
#   readability-braces-around-statements - 1830 purely cosmetic; noisy diff.

Checks: >
  -*,
  modernize-use-override,
  modernize-use-bool-literals,
  modernize-redundant-void-arg,
  modernize-use-equals-default,
  modernize-use-equals-delete,
  readability-redundant-member-init,
  readability-redundant-control-flow

# Treat nothing as an error yet — this is a reporting/assist pass, not a gate.
WarningsAsErrors: ''

# Only analyze our own code; never touch vendored SFML or third-party headers.
HeaderFilterRegex: 'src/liblt/.*'

FormatStyle: file
